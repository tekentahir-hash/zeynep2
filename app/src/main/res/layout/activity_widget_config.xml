<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg">

    <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
        android:background="@color/primary" android:gravity="center_vertical" android:paddingStart="16dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/configure_widget" android:textColor="#FFF"
            android:textSize="18sp" android:textStyle="bold"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="12dp">

            <!-- ── DOSYA ── -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="10dp"
                app:cardCornerRadius="10dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📄 HTML Dosyası" android:textStyle="bold"
                        android:textColor="@color/primary" android:textSize="13sp" android:layout_marginBottom="8dp"/>
                    <TextView android:id="@+id/tv_file" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:text="@string/no_file"
                        android:textSize="12sp" android:background="#F1F5F9" android:padding="8dp"
                        android:minHeight="38dp" android:gravity="center_vertical" android:layout_marginBottom="8dp"/>
                    <Button android:id="@+id/btn_file" android:layout_width="match_parent"
                        android:layout_height="42dp" android:text="@string/select_file"
                        android:textAllCaps="false" android:backgroundTint="@color/primary"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── WIDGET BOYUTU ── -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="10dp"
                app:cardCornerRadius="10dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📐 Widget Boyutu" android:textStyle="bold"
                        android:textColor="@color/primary" android:textSize="13sp" android:layout_marginBottom="10dp"/>

                    <!-- Preset butonları - satır 1 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <Button android:id="@+id/btn_1x1"
                            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                            android:text="1×1" android:textSize="13sp" android:textAllCaps="false"
                            android:layout_marginEnd="6dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                        <Button android:id="@+id/btn_1x2"
                            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                            android:text="1×2" android:textSize="13sp" android:textAllCaps="false"
                            android:layout_marginEnd="6dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                        <Button android:id="@+id/btn_2x2"
                            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                            android:text="2×2" android:textSize="13sp" android:textAllCaps="false"
                            android:layout_marginEnd="6dp"
                            android:backgroundTint="@color/primary"/>
                        <Button android:id="@+id/btn_1x4"
                            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                            android:text="1×4" android:textSize="13sp" android:textAllCaps="false"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                    </LinearLayout>

                    <!-- Ayırıcı -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#E2E8F0" android:layout_marginVertical="10dp"/>

                    <!-- Serbest sayı girişi -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Özel boyut (dp):" android:textSize="12sp"
                        android:textColor="@color/text2" android:layout_marginBottom="6dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Genişlik" android:textSize="11sp" android:textColor="@color/text2"
                            android:layout_marginEnd="4dp"/>
                        <EditText android:id="@+id/et_width_dp"
                            android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                            android:inputType="number" android:text="148" android:textSize="15sp"
                            android:gravity="center" android:padding="4dp" android:background="@drawable/input_bg"/>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="  ×  " android:textSize="16sp" android:textColor="@color/text1"
                            android:textStyle="bold"/>

                        <EditText android:id="@+id/et_height_dp"
                            android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                            android:inputType="number" android:text="148" android:textSize="15sp"
                            android:gravity="center" android:padding="4dp" android:background="@drawable/input_bg"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="  Yükseklik" android:textSize="11sp" android:textColor="@color/text2"
                            android:layout_marginStart="4dp"/>
                    </LinearLayout>

                    <!-- Aktif boyut etiketi -->
                    <TextView android:id="@+id/tv_size_label"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="✔ 2×2  —  148 × 148 dp"
                        android:textSize="12sp" android:textColor="@color/primary"
                        android:textStyle="bold" android:background="#EEF4FF"
                        android:padding="8dp" android:gravity="center"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── ÖNİZLEME + KONUM ── -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="10dp"
                app:cardCornerRadius="10dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔍 Görünüm Konumu" android:textStyle="bold"
                        android:textColor="@color/primary" android:textSize="13sp" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/scroll_hint" android:textSize="11sp"
                        android:textColor="@color/text2" android:layout_marginBottom="8dp"/>

                    <FrameLayout android:layout_width="match_parent" android:layout_height="200dp"
                        android:background="#DDDDDD" android:layout_marginBottom="10dp">
                        <WebView android:id="@+id/wv_preview" android:layout_width="match_parent"
                            android:layout_height="match_parent" android:background="#FFFFFF"/>
                        <com.htmlwidget.SelectionOverlayView android:id="@+id/overlay"
                            android:layout_width="match_parent" android:layout_height="match_parent"/>
                        <TextView android:id="@+id/tv_preview_hint"
                            android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:text="@string/preview_loading"
                            android:textColor="#888" android:textSize="12sp"/>
                    </FrameLayout>

                    <!-- X -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/scroll_x" android:textSize="12sp"
                        android:textColor="@color/text2" android:layout_marginBottom="2dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <SeekBar android:id="@+id/seek_scroll_x" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:max="5000" android:progress="0"/>
                        <EditText android:id="@+id/et_scroll_x" android:layout_width="72dp"
                            android:layout_height="36dp" android:inputType="number" android:text="0"
                            android:textSize="12sp" android:gravity="center" android:layout_marginStart="8dp"
                            android:padding="4dp" android:background="@drawable/input_bg"/>
                    </LinearLayout>

                    <!-- Y -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/scroll_y" android:textSize="12sp"
                        android:textColor="@color/text2" android:layout_marginBottom="2dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <SeekBar android:id="@+id/seek_scroll_y" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:max="10000" android:progress="0"/>
                        <EditText android:id="@+id/et_scroll_y" android:layout_width="72dp"
                            android:layout_height="36dp" android:inputType="number" android:text="0"
                            android:textSize="12sp" android:gravity="center" android:layout_marginStart="8dp"
                            android:padding="4dp" android:background="@drawable/input_bg"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── ZOOM + BEKLEME ── -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="10dp"
                app:cardCornerRadius="10dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔎 Zoom ve Yükleme" android:textStyle="bold"
                        android:textColor="@color/primary" android:textSize="13sp" android:layout_marginBottom="10dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/zoom" android:textSize="12sp"
                        android:textColor="@color/text2" android:layout_marginBottom="2dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <SeekBar android:id="@+id/seek_zoom" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:max="490" android:progress="90"/>
                        <EditText android:id="@+id/et_zoom" android:layout_width="72dp"
                            android:layout_height="36dp" android:inputType="number" android:text="100"
                            android:textSize="12sp" android:gravity="center" android:layout_marginStart="8dp"
                            android:padding="4dp" android:background="@drawable/input_bg"/>
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/render_delay" android:textSize="12sp"
                        android:textColor="@color/text2" android:layout_marginBottom="2dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <SeekBar android:id="@+id/seek_delay" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:max="100" android:progress="15"/>
                        <EditText android:id="@+id/et_delay" android:layout_width="72dp"
                            android:layout_height="36dp" android:inputType="numberDecimal" android:text="1.5"
                            android:textSize="12sp" android:gravity="center" android:layout_marginStart="8dp"
                            android:padding="4dp" android:background="@drawable/input_bg"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── YENİLEME ── -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="10dp"
                app:cardCornerRadius="10dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔄 Yenileme Süresi" android:textStyle="bold"
                        android:textColor="@color/primary" android:textSize="13sp" android:layout_marginBottom="6dp"/>
                    <TextView android:id="@+id/tv_interval_label" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="15 dakika"
                        android:textSize="13sp" android:textColor="@color/text1"
                        android:textStyle="bold" android:layout_marginBottom="4dp"/>
                    <SeekBar android:id="@+id/seek_interval" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:max="1000"
                        android:progress="200" android:layout_marginBottom="10dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <EditText android:id="@+id/et_interval_val" android:layout_width="90dp"
                            android:layout_height="40dp" android:inputType="numberDecimal"
                            android:text="15" android:textSize="14sp" android:gravity="center"
                            android:padding="4dp" android:background="@drawable/input_bg"/>
                        <Spinner android:id="@+id/spinner_unit" android:layout_width="0dp"
                            android:layout_height="40dp" android:layout_weight="1"
                            android:layout_marginStart="8dp" android:background="@drawable/input_bg"
                            android:padding="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Alt butonlar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:background="@color/surface"
        android:elevation="6dp" android:padding="10dp">
        <Button android:id="@+id/btn_cancel" android:layout_width="0dp" android:layout_height="46dp"
            android:layout_weight="1" android:text="@string/cancel" android:textAllCaps="false"
            android:layout_marginEnd="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        <Button android:id="@+id/btn_add" android:layout_width="0dp" android:layout_height="46dp"
            android:layout_weight="2" android:text="@string/add_widget" android:textAllCaps="false"
            android:backgroundTint="@color/primary"/>
    </LinearLayout>

</LinearLayout>
